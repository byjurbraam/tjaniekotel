# Copy this file to .env, then edit it before public deployment.
# Do not commit .env to GitHub.

PROJECT_NAME=retro_hotel
PROJECT_TITLE="Retro Hotel"

# Upstream Docker stack. This starter pulls the source on first bootstrap.
UPSTREAM_REPO=https://github.com/Gurkengewuerz/nitro-docker.git
UPSTREAM_REF=main
UPSTREAM_DIR=vendor/nitro-docker

# Public domains. Point all of these A/AAAA records to your VPS.
DOMAIN_CMS=example.com
DOMAIN_GAME=game.example.com
DOMAIN_ASSETS=assets.example.com
DOMAIN_WS=ws.example.com
ROOT_DOMAIN=example.com

# Public schemes used when rendering SQL/config helpers.
PUBLIC_SCHEME=https
WEBSOCKET_SCHEME=wss

# Used by Caddy for Let's Encrypt account registration.
ACME_EMAIL=admin@example.com

# Database credentials. Replace all CHANGE_ME values before going online.
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
MYSQL_USER=arcturus_user
MYSQL_PASSWORD=CHANGE_ME_DB_PASSWORD
MYSQL_DATABASE=arcturus

# Emulator settings. Keep RCON bound to localhost/internal unless you know exactly why you need remote RCON.
EMU_HOST=0.0.0.0
EMU_PORT=3000
RCON_HOST=127.0.0.1
RCON_PORT=3001
RCON_ALLOWED=127.0.0.1
RT_THREADS=12

# Imager settings used by the upstream stack.
API_HOST=imager
API_PORT=3000
AVATAR_SAVE_PATH=/app/assets/usercontent/avatar/
IMAGEPROXY_ADDR=0.0.0.0:8080
IMAGEPROXY_CACHE=/tmp/imageproxy
IMAGEPROXY_USER_AGENT="Mozilla/5.0 (compatible; RetroHotelDockerStarter/1.0)"
